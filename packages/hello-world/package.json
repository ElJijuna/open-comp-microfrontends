{
  "name": "@open-comp/hello-world",
  "version": "0.1.0",
  "description": "Dummy widget for testing the open-comp pipeline",
  "main": "dist/index.umd.js",
  "module": "dist/index.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.es.js",
      "require": "./dist/index.umd.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "npm run build:lib && npm run build:types && npm run build:federation",
    "build:types": "tsc",
    "build:lib": "vite build",
    "build:federation": "BUILD_MODE=federation vite build",
    "dev": "vite build --watch",
    "lint": "eslint src"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@originjs/vite-plugin-federation": "^1.4.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^6.0.0",
    "vite": "^8.0.0"
  }
}
