{
  "name": "@open-comp/gh",
  "version": "0.1.0",
  "description": "GitHub-scoped open components for the open-comp ecosystem",
  "main": "dist/index.umd.js",
  "module": "dist/index.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.umd.js"
    },
    "./GitHubProfile": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.umd.js"
    },
    "./GitHubContributions": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.umd.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run build:lib && npm run build:types && npm run build:federation",
    "build:types": "tsc",
    "build:lib": "vite build",
    "build:federation": "BUILD_MODE=federation vite build",
    "dev": "vite build --watch",
    "lint": "eslint src"
  },
  "peerDependencies": {
    "@api-hooks/gh": ">=2.5.1",
    "@gnome-ui/icons": ">=1.42.1",
    "@gnome-ui/react": ">=1.50.0",
    "@tanstack/react-query": ">=5.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@api-hooks/gh": "^2.5.1",
    "@gnome-ui/hooks": "^1.28.1",
    "@gnome-ui/icons": "^1.42.1",
    "@gnome-ui/layout": "^1.30.1",
    "@gnome-ui/react": "^1.50.0",
    "@originjs/vite-plugin-federation": "^1.4.0",
    "@tanstack/react-query": "^5.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^6.0.0",
    "vite": "^8.0.0"
  }
}
